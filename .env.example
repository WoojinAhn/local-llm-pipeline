# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.
#
# Shell environment variables override .env values, so you can still pass
# keys explicitly via `KEY=value python3 ...` if needed.

# Web search APIs (optional — search step is gracefully skipped if missing)
BRAVE_API_KEY=
TAVILY_API_KEY=

# HuggingFace token (required for gated models like FLUX.2-dev,
# also recommended to avoid rate limits on large model downloads)
HF_TOKEN=
